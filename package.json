{
  "name": "mycelium-os",
  "private": true,
  "pnpm": {
    "overrides": {
      "next": "14.2.35"
    }
  },
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "test": "pnpm --filter frontend test",
    "build": "pnpm --filter frontend build",
    "storybook": "pnpm --filter frontend storybook",
    "build-storybook": "pnpm --filter frontend build-storybook",
    "shroom:validate": "pnpm --filter @mycelium/shroom-manifest validate",
    "openspec": "openspec",
    "openspec:update": "openspec update"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "mcp-remote": "0.1.38",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@9.14.2"
}
