POSTGRES_USER=mycelium
POSTGRES_PASSWORD=mycelium
POSTGRES_DB=mycelium
DATABASE_URL=postgresql://mycelium:mycelium@localhost:5432/mycelium

NEO4J_AUTH=neo4j/changeme

NATS_URL=nats://localhost:4222

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST_PORT=11435

OPENROUTER_API_KEY=

DEV_API_KEY=                 # control plane auth key
DEV_PRINCIPAL_ID=dev-user
DEMO_ENABLED=false

# Frontend proxy (server-side; never use NEXT_PUBLIC_ for secrets)
CONTROL_PLANE_URL=http://localhost:8000
CONTROL_PLANE_API_KEY=       # must equal DEV_API_KEY — injected as X-API-Key on every proxied request
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8000  # WebSocket URL (public, non-secret)
